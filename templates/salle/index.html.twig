{% extends 'base.html.twig' %}
{% block title %}Salles{% endblock %}
{% block page_title %}Salles{% endblock %}

{% block body %}
<div class="d-flex justify-content-end mb-3">
    <a href="{{ path('app_salle_new') }}" class="btn btn-primary"><i class="ti ti-plus"></i> Ajouter</a>
</div>
<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Code</th><th>Capacité</th><th>Localisation</th><th>Actions</th></tr>
            </thead>
            <tbody>
                {% for s in salles %}
                <tr>
                    <td>{{ s.code }}</td><td>{{ s.capacite }}</td><td>{{ s.localisation }}</td>
                    <td>
                        <a href="{{ path('app_salle_edit', {id: s.id}) }}" class="btn btn-sm btn-outline-primary"><i class="ti ti-edit"></i></a>
                        <form method="post" action="{{ path('app_salle_delete', {id: s.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete'~s.id) }}">
                            <button class="btn btn-sm btn-outline-danger"><i class="ti ti-trash"></i></button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="4" class="text-center text-muted py-3">Aucune salle</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}