{% extends 'base.html.twig' %}
{% block title %}Mon tableau de bord{% endblock %}
{% block page_title %}Tableau de bord{% endblock %}

{% block body %}


<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div style="background:linear-gradient(135deg,#534AB7,#7C6FCD);border-radius:12px;padding:16px 18px;color:#fff">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span style="font-size:11px;font-weight:600;letter-spacing:.08em;opacity:.8;text-transform:uppercase">Mes soutenances</span>
                <div style="background:rgba(255,255,255,.2);border-radius:7px;padding:5px 6px"><i class="ti ti-calendar-event" style="font-size:16px"></i></div>
            </div>
            <div style="font-size:30px;font-weight:700;line-height:1">{{ nbSoutenances }}</div>
            <div style="font-size:11px;opacity:.75;margin-top:3px">programmées au total</div>
            <hr style="border-color:rgba(255,255,255,.2);margin:10px 0">
            <a href="{{ path('app_enseignant_soutenances') }}" style="font-size:11px;color:#fff;text-decoration:none;opacity:.9">Voir la liste <i class="ti ti-arrow-right" style="font-size:11px"></i></a>
        </div>
    </div>
</div>

<div style="background:#fff;border-radius:14px;border:1px solid #e5e7eb;padding:24px">
    <div style="font-size:15px;font-weight:600;color:#111;margin-bottom:4px">Mes soutenances programmées</div>
    <div style="font-size:12px;color:#6b7280;margin-bottom:16px">Liste de vos participations aux jurys</div>
    <table class="table table-hover mb-0" style="font-size:13px">
        <thead>
            <tr style="border-bottom:2px solid #f0f0f0">
                <th style="font-size:11px;color:#6b7280;font-weight:600;text-transform:uppercase;letter-spacing:.05em;border:none">Étudiant</th>
                <th style="font-size:11px;color:#6b7280;font-weight:600;text-transform:uppercase;letter-spacing:.05em;border:none">Thème</th>
                <th style="font-size:11px;color:#6b7280;font-weight:600;text-transform:uppercase;letter-spacing:.05em;border:none">Date</th>
                <th style="font-size:11px;color:#6b7280;font-weight:600;text-transform:uppercase;letter-spacing:.05em;border:none">Heure</th>
                <th style="font-size:11px;color:#6b7280;font-weight:600;text-transform:uppercase;letter-spacing:.05em;border:none">Salle</th>
                <th style="font-size:11px;color:#6b7280;font-weight:600;text-transform:uppercase;letter-spacing:.05em;border:none">Rôle</th>
            </tr>
        </thead>
        <tbody>
            {% for s in soutenances %}
            <tr>
                <td style="font-weight:500">{{ s.etudiant.nom }} {{ s.etudiant.prenom }}</td>
                <td style="color:#6b7280">{{ s.etudiant.themeMemoire }}</td>
                <td>{{ s.date|date('d/m/Y') }}</td>
                <td>{{ s.heure|date('H:i') }}</td>
                <td><span style="background:#f0f0f0;padding:2px 8px;border-radius:6px;font-size:12px">{{ s.salle.code }}</span></td>
                <td>
                    {% if s.president == enseignant %}
                        <span style="background:#dbeafe;color:#1e40af;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600">Président</span>
                    {% elseif s.rapporteur == enseignant %}
                        <span style="background:#d1fae5;color:#065f46;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600">Rapporteur</span>
                    {% else %}
                        <span style="background:#f3f4f6;color:#374151;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600">Examinateur</span>
                    {% endif %}
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="6" class="text-center py-4" style="color:#9ca3af">
                    <i class="ti ti-calendar-off" style="font-size:28px;display:block;margin-bottom:6px"></i>
                    Aucune soutenance programmée
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}