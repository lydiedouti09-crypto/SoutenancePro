{% extends 'base.html.twig' %}
{% block title %}Soutenances{% endblock %}
{% block page_title %}Soutenances{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <form class="d-flex gap-2" method="get">
        <input type="date" name="date" class="form-control" value="{{ date }}">
        <button class="btn btn-outline-secondary">Filtrer</button>
        <a href="{{ path('app_soutenance_index') }}" class="btn btn-outline-secondary">Réinitialiser</a>
    </form>
    <a href="{{ path('app_soutenance_new') }}" class="btn btn-primary"><i class="ti ti-plus"></i> Programmer</a>
</div>
<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Étudiant</th><th>Date</th><th>Heure</th><th>Salle</th><th>Président</th><th>Rapporteur</th><th>Examinateur</th><th>Actions</th></tr>
            </thead>
            <tbody>
                {% for s in soutenances %}
                <tr>
                    <td>{{ s.etudiant.nom }} {{ s.etudiant.prenom }}</td>
                    <td>{{ s.date|date('d/m/Y') }}</td>
                    <td>{{ s.heure|date('H:i') }}</td>
                    <td>{{ s.salle.code }}</td>
                    <td>{{ s.president.nom }}</td>
                    <td>{{ s.rapporteur.nom }}</td>
                    <td>{{ s.examinateur.nom }}</td>
                    <td>
                        <a href="{{ path('app_soutenance_edit', {id: s.id}) }}" class="btn btn-sm btn-outline-primary"><i class="ti ti-edit"></i></a>
                        <form method="post" action="{{ path('app_soutenance_delete', {id: s.id}) }}" class="d-inline" onsubmit="return confirm('Annuler cette soutenance ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete'~s.id) }}">
                            <button class="btn btn-sm btn-outline-danger"><i class="ti ti-trash"></i></button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="8" class="text-center text-muted py-3">Aucune soutenance</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}