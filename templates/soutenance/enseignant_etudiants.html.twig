{% extends 'base.html.twig' %}
{% block title %}Mes étudiants{% endblock %}
{% block page_title %}Mes étudiants{% endblock %}

{% block body %}
<div style="background:#fff;border-radius:14px;border:1px solid #e5e7eb;padding:0;overflow:hidden">
    <table class="table table-hover mb-0">
        <thead class="table-light">
            <tr><th>Nom</th><th>Prénom</th><th>Email</th><th>Filière</th><th>Thème du mémoire</th></tr>
        </thead>
        <tbody>
            {% for e in etudiants %}
            <tr>
                <td>{{ e.nom }}</td>
                <td>{{ e.prenom }}</td>
                <td>{{ e.email }}</td>
                <td>{{ e.filiere }}</td>
                <td>{{ e.themeMemoire }}</td>
            </tr>
            {% else %}
            <tr><td colspan="5" class="text-center text-muted py-3">Aucun étudiant affecté</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}